{
    "name": "woocommerce/woocommerce-shipping-dhl",
    "description": "DHL Express Shipping for WooCommerce provides live rates, shipment creation, pickups, tracking, and related DHL Express workflows through the MyDHL API.",
    "homepage": "https://woocommerce.com/products/dhl-shipping-method/",
    "type": "wordpress-plugin",
    "license": "GPL-3.0-or-later",
    "require": {
        "php": ">=7.4",
        "automattic/jetpack-autoloader": "^2.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "woocommerce/woocommerce-sniffs": "^1.0.1",
        "yoast/phpunit-polyfills": "^3.0",
        "phpstan/phpstan": "^2.1",
        "php-stubs/wordpress-stubs": "^6.6",
        "php-stubs/woocommerce-stubs": "^9.5",
        "szepeviktor/phpstan-wordpress": "^2.0"
    },
    "config": {
        "allow-plugins": {
            "automattic/jetpack-autoloader": true,
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    },
    "autoload": {
        "psr-4": {
            "WooCommerce\\DHL\\": "includes/"
        }
    },
    "scripts": {
        "phpcs": [
            "phpcs -d memory_limit=1G --extensions=php --standard=phpcs.xml.dist includes woocommerce-shipping-dhl.php bin"
        ],
        "phpcbf": [
            "phpcbf -d memory_limit=1G --extensions=php --standard=phpcs.xml.dist includes woocommerce-shipping-dhl.php bin"
        ],
        "phpstan": [
            "phpstan analyse --memory-limit=1G --configuration=phpstan.neon.dist"
        ],
        "test": [
            "phpunit"
        ]
    }
}
